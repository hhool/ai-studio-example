{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email"]
    },
    "Bookmark": {
      "title": "Baby Bike Bookmark",
      "description": "Product bookmarked by user",
      "type": "object",
      "properties": {
        "productId": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["productId", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile metadata"
    },
    "/users/{userId}/bookmarks/{bookmarkId}": {
      "schema": "Bookmark",
      "description": "Saved products for the user"
    }
  }
}
