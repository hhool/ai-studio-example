rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity validator: User Profile
    function isValidUser(user) {
      return user.keys().hasAll(['userId', 'email'])
          && user.keys().size() == 2
          && user.userId == request.auth.uid
          && user.email is string
          && user.email.size() <= 256;
    }

    // Entity validator: Bookmark
    function isValidBookmark(bookmark) {
      return bookmark.keys().hasAll(['productId', 'userId', 'createdAt'])
          && bookmark.keys().size() == 3
          && bookmark.userId == request.auth.uid
          && bookmark.productId is string
          && bookmark.productId.size() <= 128
          && bookmark.createdAt == request.time;
    }

    // Match rules for user accounts and subcollections
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.email == resource.data.email;
      allow delete: if false;

      match /bookmarks/{bookmarkId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(bookmarkId) && isValidBookmark(request.resource.data);
        allow delete: if isOwner(userId) && isValidId(bookmarkId);
        allow update: if false;
      }
    }
  }
}
